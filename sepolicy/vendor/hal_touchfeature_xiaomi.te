type hal_touchfeature_xiaomi_default, domain;
type hal_touchfeature_xiaomi_default_exec, exec_type, file_type, vendor_file_type;
type hal_touchfeature_xiaomi_service, hal_service_type, protected_service, service_manager_type;

binder_call(hal_touchfeature_xiaomi_default, system_server)
binder_use(hal_touchfeature_xiaomi_server)
hal_server_domain(hal_touchfeature_xiaomi_default, hal_touchfeature_xiaomi)
init_daemon_domain(hal_touchfeature_xiaomi_default)
unix_socket_connect(hal_touchfeature_xiaomi_default, property, touchreport)
unix_socket_connect(hal_touchfeature_xiaomi_default, property, tpevent)
vndbinder_use(hal_touchfeature_xiaomi)

set_prop(hal_touchfeature_xiaomi_default, vendor_touch_hostprocess_prop)
set_prop(hal_touchfeature_xiaomi_default, vendor_touchfeature_prop)

allow hal_touchfeature_xiaomi touchfeature_device:chr_file rw_file_perms;
allow hal_touchfeature_xiaomi_client hal_touchfeature_xiaomi_server:binder { call transfer };
allow hal_touchfeature_xiaomi_client hal_touchfeature_xiaomi_server:fd *;
allow hal_touchfeature_xiaomi_client hal_touchfeature_xiaomi_service:service_manager find;
allow hal_touchfeature_xiaomi_default fwk_sensor_hwservice:hwservice_manager find;
allow hal_touchfeature_xiaomi_default fwk_sensor_service:service_manager find;
allow hal_touchfeature_xiaomi_default hal_touchfeature_xiaomi_service:service_manager find;
allow hal_touchfeature_xiaomi_default input_device:chr_file rw_file_perms;
allow hal_touchfeature_xiaomi_default input_device:dir r_dir_perms;
allow hal_touchfeature_xiaomi_default mnt_vendor_file:dir { w_dir_perms getattr read rmdir };
allow hal_touchfeature_xiaomi_default mnt_vendor_file:file { create getattr open read setattr unlink write };
allow hal_touchfeature_xiaomi_default proc_tp_file:file { open read write };
allow hal_touchfeature_xiaomi_default self:cap_userns sys_nice;
allow hal_touchfeature_xiaomi_default self:capability sys_nice;
allow hal_touchfeature_xiaomi_default self:qipcrtr_socket { create getattr read setopt write };
allow hal_touchfeature_xiaomi_default servicemanager:binder { call transfer };
allow hal_touchfeature_xiaomi_default surfaceflinger:binder { call transfer };
allow hal_touchfeature_xiaomi_default sysfs:file { getattr open read write };
allow hal_touchfeature_xiaomi_default sysfs_touch_hostprocess:file rw_file_perms;
allow hal_touchfeature_xiaomi_default sysfs_touch_suspend:file rw_file_perms;
allow hal_touchfeature_xiaomi_default sysfs_tp_virtual_prox:file rw_file_perms;
allow hal_touchfeature_xiaomi_default system_app:binder call;
allow hal_touchfeature_xiaomi_default system_server:binder call;
allow hal_touchfeature_xiaomi_default touchfeature_device:chr_file rw_file_perms;
allow hal_touchfeature_xiaomi_default touchfeature_device:file { getattr map read };
allow hal_touchfeature_xiaomi_default touchreport_data_file:dir rw_dir_perms;
allow hal_touchfeature_xiaomi_default touchreport_data_file:file { open read };
allow hal_touchfeature_xiaomi_default touchreport_exec:file entrypoint;
allow hal_touchfeature_xiaomi_default uhid_device:chr_file rw_file_perms;
allow hal_touchfeature_xiaomi_default vendor_bsp_data_log_file:dir create_dir_perms;
allow hal_touchfeature_xiaomi_default vendor_bsp_data_log_file:file create_file_perms;
allow hal_touchfeature_xiaomi_default vendor_data_touchreport_file:dir { add_name read remove_name search watch write };
allow hal_touchfeature_xiaomi_default vendor_data_touchreport_file:file { create getattr open read rename setattr unlink write };
allow hal_touchfeature_xiaomi_default vendor_touchfeature_prop:file { getattr open read };
allow hal_touchfeature_xiaomi_server hal_touchfeature_xiaomi_client:binder transfer;
allow hal_touchfeature_xiaomi_server hal_touchfeature_xiaomi_service:service_manager { add find };
